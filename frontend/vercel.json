{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path*\\.(js|css|woff2|woff|ttf|png|jpg|svg|ico|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://urbanthreadss.onrender.com/api/:path*"
    },
    {
      "source": "/:path((?!api|assets|.*\\..*).*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|facebook|whatsapp|twitter|pinterest|slack|linkedin|skype|discord|telegram|viber).*"
        }
      ],
      "destination": "https://urbanthreadss.onrender.com/:path"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}