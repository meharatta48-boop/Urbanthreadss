{
  "name": "backend",
  "version": "1.0.0",
  "description": "Ecommerce Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "predev": "powershell -Command \"$p = (netstat -ano | Select-String ':5001').ToString().Trim().Split()[-1]; if ($p -and $p -ne '0') { taskkill /PID $p /F 2>$null }\" 2>nul || exit 0",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "colors": "^1.4.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.6.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "sanitize-html": "^2.17.0",
    "supertest": "^7.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
